// nextflow.config
profiles {
    standard {
        process.executor = 'local'
    }

    sapelo2 {
        process {
            // DEFAULT: For standard CPU tasks
            executor = 'slurm'
            queue = 'batch'
            memory = '16 GB'
            time = '2h'
            cpus = 4
            clusterOptions = '--ntasks=1'

            // Load the environment on every worker node
            beforeScript = '''
            module load Miniforge3
            eval "$(conda shell.bash hook)"
            conda activate /work/ah2lab/LiamK/conda_envs/plm_dynamics
            export LD_LIBRARY_PATH=$CONDA_PREFIX/lib:$LD_LIBRARY_PATH
            '''

            // HEAVY CPU: Maximize data generation
            withName: 'GEN_SOURCE|GEN_TARGET' {
                memory = '32 GB'
                time = '4h'
                maxForks = 100  // Safely run 100 parallel batch jobs
            }

            // GPU TASKS: Ride the exact submission limit
            withName: 'TRAIN_SOURCE' {
                queue = 'gpu_p'
                clusterOptions = '--ntasks=1 --gres=gpu:A100:1 --exclude=b6-2'
                memory = '32 GB'
                time = '12h'
                maxForks = 10  // Takes half of the 20-job limit
            }
            
            withName: 'TEST_ADAPTATION' {
                queue = 'gpu_p'
                clusterOptions = '--ntasks=1 --gres=gpu:A100:1 --exclude=b6-2'
                memory = '32 GB'
                time = '12h'
                maxForks = 10  // Takes the other half of the 20-job limit
            }
        }
    }
}

params {
    outdir = "results/run_${new Date().format('yyyyMMdd_HHmmss')}"
}
