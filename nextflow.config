// nextflow.config
log {
    file = 'logs/nextflow/nextflow.log'
}

profiles {
    standard {
        process.executor = 'local'
    }

    // --------------------------------------------------------------------------
    // PERSONAL PROFILE (Sapelo2 @ UGA) — author's site-specific configuration.
    // Shielded from public release; reference only. Use 'slurm' for portability.
    // --------------------------------------------------------------------------
    liam_sapelo2 {
        process {
            // DEFAULT: For standard CPU tasks
            executor = 'slurm'
            queue = 'batch'
            memory = '16 GB'
            time = '2h'
            cpus = 4
            clusterOptions = '--ntasks=1'

            // Load the environment on every worker node
            beforeScript = '''
            module load Miniforge3
            eval "$(conda shell.bash hook)"
            conda activate /work/ah2lab/LiamK/conda_envs/plm_dynamics
            export LD_LIBRARY_PATH=$CONDA_PREFIX/lib:$LD_LIBRARY_PATH
            '''

            // HEAVY CPU: Maximize data generation
            withName: 'GEN_SOURCE|GEN_TARGET' {
                memory = '32 GB'
                time = '4h'
                maxForks = 100  // Safely run 100 parallel batch jobs
            }

            // GPU TASKS: Ride the exact submission limit
            withName: 'TRAIN_SOURCE' {
                queue = 'gpu_p'
                clusterOptions = '--ntasks=1 --gres=gpu:A100:1 --exclude=b6-2'
                memory = '32 GB'
                time = '12h'
                maxForks = 10  // Takes half of the 20-job limit
            }

            withName: 'TEST_ADAPTATION' {
                queue = 'gpu_p'
                clusterOptions = '--ntasks=1 --gres=gpu:A100:1 --exclude=b6-2'
                memory = '32 GB'
                time = '12h'
                maxForks = 10  // Takes the other half of the 20-job limit
            }
        }
    }

    // --------------------------------------------------------------------------
    // GENERIC SLURM PROFILE — portable to any SLURM cluster.
    // Makes NO assumptions about partition/queue names or environment modules.
    //   * Set your CPU/GPU partitions by uncommenting the `queue` lines below.
    //   * Ensure python/nextflow/torch are on the worker PATH (module load,
    //     conda activate, or a container) before launching, OR add a beforeScript.
    // --------------------------------------------------------------------------
    slurm {
        process {
            // DEFAULT: standard CPU tasks
            executor = 'slurm'
            // queue = '<your_cpu_partition>'    // <-- EDIT: uncomment & set
            memory = '16 GB'
            time = '2h'
            cpus = 4
            clusterOptions = '--ntasks=1'

            // Activate your environment on every worker node.
            // EDIT for your site (module load / conda activate / source venv),
            // or remove if python/torch are already on the default PATH.
            //
            // beforeScript = '''
            // module load Anaconda3
            // source activate my_env
            // '''

            // HEAVY CPU: data generation
            withName: 'GEN_SOURCE|GEN_TARGET' {
                memory = '32 GB'
                time = '4h'
                maxForks = 20   // EDIT: cap to your cluster's concurrency limits
            }

            // GPU TASKS: training + adaptation.
            // Request a single generic GPU. EDIT gres type/count + GPU partition.
            withName: 'TRAIN_SOURCE' {
                // queue = '<your_gpu_partition>'    // <-- EDIT: uncomment & set
                clusterOptions = '--ntasks=1 --gres=gpu:1'
                memory = '32 GB'
                time = '12h'
                maxForks = 4
            }

            withName: 'TEST_ADAPTATION' {
                // queue = '<your_gpu_partition>'    // <-- EDIT: uncomment & set
                clusterOptions = '--ntasks=1 --gres=gpu:1'
                memory = '32 GB'
                time = '12h'
                maxForks = 4
            }
        }
    }
}

params {
    outdir = "results/run_${new Date().format('yyyyMMdd_HHmmss')}"
}
