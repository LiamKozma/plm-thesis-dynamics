// 1. AWS Connectivity (The Bridge)
// This tells Nextflow to use the 'sapelo' profile in your ~/.aws/config
aws {
    region = 'us-east-1'
    profile = 'sapelo' 
}

// 2. Default Parameters
params {
    // Your S3 Data Lake bucket (created in the previous step)
    outdir = "s3://uga-thesis-plm-kozma/results/"
}

// 3. Profiles
profiles {
    standard {
        process.executor = 'local'
    }
    
    // We will use this later for the cluster
    sapelo2 {
        process.executor = 'slurm'
        // 'process.module' loads the software on the cluster
        process.module = 'Apptainer/1.3.4-GCC-13.3.0' 
        // Enable Apptainer integration in Nextflow
        apptainer.enabled = true
        apptainer.autoMounts = true
    }
}
